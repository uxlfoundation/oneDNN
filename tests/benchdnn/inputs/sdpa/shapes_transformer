# Transformer-like SDPA shapes for GPU testing
# Q_dims:K_dims:V_dims
# Format: batch x heads x seq_q x head_size : batch x heads x head_size x seq_k : batch x heads x seq_k x head_v

# BERT-base like (12 heads, head_size=64, seq_len=128)
1x12x128x64:1x12x64x128:1x12x128x64

# BERT-large like (16 heads, head_size=64, seq_len=128)
1x16x128x64:1x16x64x128:1x16x128x64

# GPT-2 like (12 heads, head_size=64, seq=256)
1x12x256x64:1x12x64x256:1x12x256x64

# LLaMA-like (32 heads, head_size=128, seq=64)
1x32x64x128:1x32x128x64:1x32x64x128

# Batch=2
2x8x64x64:2x8x64x64:2x8x64x64

# KV-cache scenario: small query, large KV
1x8x1x64:1x8x64x256:1x8x256x64
1x8x1x64:1x8x64x512:1x8x512x64
